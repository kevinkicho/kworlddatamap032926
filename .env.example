# Yahoo Finance OAuth credentials
# Do NOT commit this file — it is listed in .gitignore
YAHOO_APP_ID=YOUR_YAHOO_APP_ID_HERE
YAHOO_CLIENT_ID=YOUR_YAHOO_CLIENT_ID_HERE
YAHOO_CLIENT_SECRET=YOUR_YAHOO_CLIENT_SECRET_HERE

#https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=YOUR_FRED_API_KEY_HERE

#https://apps.bea.gov/api/signup.asp
BEA_API_KEY=YOUR_BEA_API_KEY_HERE

#https://api.usa.gov/crime/fbi/cde (optional; DEMO_KEY used if not set, 10 req/~21hr)
FBI_API_KEY=YOUR_FBI_API_KEY_HERE

#https://www.ncdc.noaa.gov/cdo-web/token
NOAA_TOKEN=YOUR_NOAA_TOKEN_HERE

#https://api.nasa.gov/
NASA_OPEN_API_KEY=YOUR_NASA_API_KEY_HERE

#https://firms.modaps.eosdis.nasa.gov/api/map_key
NASA_MAP_KEY=YOUR_NASA_MAP_KEY_HERE

#https://aqicn.org/data-platform/token/
WAQI_TOKEN=YOUR_WAQI_TOKEN_HERE
